package com.datastax.oss.pulsar.source;

import com.datastax.oss.cdc.CassandraSourceConnectorConfig;
import com.datastax.oss.cdc.messaging.config.*;
import com.datastax.oss.cdc.messaging.schema.SchemaType;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.DisplayName;

import java.util.HashMap;
import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;

/**
 * Integration tests for CassandraSource with messaging abstraction layer.
 * Tests verify that the connector module correctly uses the messaging abstraction to consume mutations.
 * 
 * Note: These tests focus on configuration and schema handling without requiring actual Pulsar/Kafka connections.
 */
@DisplayName("Messaging Abstraction Integration Tests for Connector")
public class CassandraSourceMessagingIntegrationTest {

    private CassandraSource source;
    private Map<String, Object> config;

    @BeforeEach
    void setUp() {
        source = new CassandraSource();
        config = new HashMap<>();
        
        // Minimal configuration for testing
        config.put(CassandraSourceConnectorConfig.EVENTS_TOPIC_NAME_CONFIG, "events-test.ks1.table1");
        config.put(CassandraSourceConnectorConfig.KEYSPACE_NAME_CONFIG, "ks1");
        config.put(CassandraSourceConnectorConfig.TABLE_NAME_CONFIG, "table1");
        config.put(CassandraSourceConnectorConfig.EVENTS_SUBSCRIPTION_NAME_CONFIG, "test-subscription");
        config.put(CassandraSourceConnectorConfig.CONTACT_POINTS_OPT, "127.0.0.1");
        config.put(CassandraSourceConnectorConfig.DC_OPT, "datacenter1");
    }

    @Test
    @DisplayName("Test schema definitions initialization")
    void testSchemaDefinitionsInitialization() {
        source.initializeSchemaDefinitions();
        
        assertNotNull(source.keySchemaDefinition, "Key schema definition should be initialized");
        assertNotNull(source.valueSchemaDefinition, "Value schema definition should be initialized");
        
        assertEquals(SchemaType.AVRO, source.keySchemaDefinition.getType(),
                "Key schema type should be AVRO");
        assertEquals(SchemaType.AVRO, source.valueSchemaDefinition.getType(),
                "Value schema type should be AVRO");
        
        assertEquals("GenericRecord", source.keySchemaDefinition.getName(),
                "Key schema name should be GenericRecord");
        assertEquals("MutationValue", source.valueSchemaDefinition.getName(),
                "Value schema name should be MutationValue");
        
        assertNotNull(source.keySchemaDefinition.getNativeSchema(),
                "Key schema should have native Pulsar schema");
        assertNotNull(source.valueSchemaDefinition.getNativeSchema(),
                "Value schema should have native Pulsar schema");
    }

    @Test
    @DisplayName("Test subscription type mapping - EXCLUSIVE")
    void testSubscriptionTypeMappingExclusive() {
        SubscriptionType result = source.mapSubscriptionType("EXCLUSIVE");
        
        assertEquals(SubscriptionType.EXCLUSIVE, result,
                "Should map to EXCLUSIVE subscription type");
    }

    @Test
    @DisplayName("Test subscription type mapping - SHARED")
    void testSubscriptionTypeMappingShared() {
        SubscriptionType result = source.mapSubscriptionType("SHARED");
        
        assertEquals(SubscriptionType.SHARED, result,
                "Should map to SHARED subscription type");
    }

    @Test
    @DisplayName("Test subscription type mapping - FAILOVER")
    void testSubscriptionTypeMappingFailover() {
        SubscriptionType result = source.mapSubscriptionType("FAILOVER");
        
        assertEquals(SubscriptionType.FAILOVER, result,
                "Should map to FAILOVER subscription type");
    }

    @Test
    @DisplayName("Test subscription type mapping - KEY_SHARED")
    void testSubscriptionTypeMappingKeyShared() {
        SubscriptionType result = source.mapSubscriptionType("KEY_SHARED");
        
        assertEquals(SubscriptionType.KEY_SHARED, result,
                "Should map to KEY_SHARED subscription type");
    }

    @Test
    @DisplayName("Test subscription type mapping - null defaults to EXCLUSIVE")
    void testSubscriptionTypeMappingNullDefaultsToExclusive() {
        SubscriptionType result = source.mapSubscriptionType(null);
        
        assertEquals(SubscriptionType.EXCLUSIVE, result,
                "Null should default to EXCLUSIVE subscription type");
    }

    @Test
    @DisplayName("Test subscription type mapping - unknown defaults to EXCLUSIVE")
    void testSubscriptionTypeMappingUnknownDefaultsToExclusive() {
        SubscriptionType result = source.mapSubscriptionType("UNKNOWN_TYPE");
        
        assertEquals(SubscriptionType.EXCLUSIVE, result,
                "Unknown type should default to EXCLUSIVE subscription type");
    }

    @Test
    @DisplayName("Test subscription type mapping - case insensitive")
    void testSubscriptionTypeMappingCaseInsensitive() {
        SubscriptionType result1 = source.mapSubscriptionType("shared");
        SubscriptionType result2 = source.mapSubscriptionType("Shared");
        SubscriptionType result3 = source.mapSubscriptionType("SHARED");
        
        assertEquals(SubscriptionType.SHARED, result1,
                "Lowercase should map correctly");
        assertEquals(SubscriptionType.SHARED, result2,
                "Mixed case should map correctly");
        assertEquals(SubscriptionType.SHARED, result3,
                "Uppercase should map correctly");
    }

    @Test
    @DisplayName("Test schema definition properties")
    void testSchemaDefinitionProperties() {
        source.initializeSchemaDefinitions();
        
        // Verify key schema properties
        assertNotNull(source.keySchemaDefinition.getSchemaDefinition(),
                "Key schema should have schema definition string");
        assertEquals("AUTO_CONSUME", source.keySchemaDefinition.getSchemaDefinition(),
                "Key schema definition should be AUTO_CONSUME");
        
        // Verify value schema properties
        assertNotNull(source.valueSchemaDefinition.getSchemaDefinition(),
                "Value schema should have schema definition string");
        assertEquals("MutationValue", source.valueSchemaDefinition.getSchemaDefinition(),
                "Value schema definition should be MutationValue");
    }

    @Test
    @DisplayName("Test schema definitions are reusable")
    void testSchemaDefinitionsAreReusable() {
        source.initializeSchemaDefinitions();
        
        var keySchema1 = source.keySchemaDefinition;
        var valueSchema1 = source.valueSchemaDefinition;
        
        // Initialize again
        source.initializeSchemaDefinitions();
        
        var keySchema2 = source.keySchemaDefinition;
        var valueSchema2 = source.valueSchemaDefinition;
        
        // Should create new instances (not cached in this implementation)
        assertNotNull(keySchema2, "Key schema should be re-initialized");
        assertNotNull(valueSchema2, "Value schema should be re-initialized");
    }

    @Test
    @DisplayName("Test close without initialization")
    void testCloseWithoutInitialization() {
        // Should not throw when closing without initialization
        assertDoesNotThrow(() -> source.close(),
                "Close should not throw when called without initialization");
    }

    @Test
    @DisplayName("Test multiple close calls are safe")
    void testMultipleCloseCallsAreSafe() {
        // Multiple close calls should not throw
        assertDoesNotThrow(() -> {
            source.close();
            source.close();
            source.close();
        }, "Multiple close calls should be safe");
    }

    @Test
    @DisplayName("Test configuration with different subscription types")
    void testConfigurationWithDifferentSubscriptionTypes() {
        String[] subscriptionTypes = {"EXCLUSIVE", "SHARED", "FAILOVER", "KEY_SHARED"};
        
        for (String type : subscriptionTypes) {
            config.put(CassandraSourceConnectorConfig.EVENTS_SUBSCRIPTION_TYPE_CONFIG, type);
            CassandraSourceConfig sourceConfig = new CassandraSourceConfig(config);
            
            assertNotNull(sourceConfig.getEventsSubscriptionType(),
                    "Subscription type should be set for " + type);
            assertEquals(type, sourceConfig.getEventsSubscriptionType(),
                    "Subscription type should match for " + type);
        }
    }

    @Test
    @DisplayName("Test schema type consistency")
    void testSchemaTypeConsistency() {
        source.initializeSchemaDefinitions();
        
        // Both schemas should use AVRO type
        assertEquals(source.keySchemaDefinition.getType(), 
                source.valueSchemaDefinition.getType(),
                "Key and value schemas should use same schema type");
        
        assertEquals(SchemaType.AVRO, source.keySchemaDefinition.getType(),
                "Schema type should be AVRO");
    }

    @Test
    @DisplayName("Test native schema wrapper presence")
    void testNativeSchemaWrapperPresence() {
        source.initializeSchemaDefinitions();
        
        // Verify native schemas are present (Pulsar-specific)
        assertNotNull(source.keySchemaDefinition.getNativeSchema(),
                "Key schema should have native Pulsar schema wrapper");
        assertNotNull(source.valueSchemaDefinition.getNativeSchema(),
                "Value schema should have native Pulsar schema wrapper");
        
        // Verify they are Pulsar Schema instances
        assertTrue(source.keySchemaDefinition.getNativeSchema() instanceof org.apache.pulsar.client.api.Schema,
                "Native key schema should be Pulsar Schema instance");
        assertTrue(source.valueSchemaDefinition.getNativeSchema() instanceof org.apache.pulsar.client.api.Schema,
                "Native value schema should be Pulsar Schema instance");
    }

    @Test
    @DisplayName("Test subscription type mapping preserves enum values")
    void testSubscriptionTypeMappingPreservesEnumValues() {
        // Test all valid subscription types
        assertEquals(SubscriptionType.EXCLUSIVE, source.mapSubscriptionType("EXCLUSIVE"));
        assertEquals(SubscriptionType.SHARED, source.mapSubscriptionType("SHARED"));
        assertEquals(SubscriptionType.FAILOVER, source.mapSubscriptionType("FAILOVER"));
        assertEquals(SubscriptionType.KEY_SHARED, source.mapSubscriptionType("KEY_SHARED"));
        
        // Verify enum values are distinct
        assertNotEquals(SubscriptionType.EXCLUSIVE, SubscriptionType.SHARED);
        assertNotEquals(SubscriptionType.EXCLUSIVE, SubscriptionType.FAILOVER);
        assertNotEquals(SubscriptionType.EXCLUSIVE, SubscriptionType.KEY_SHARED);
        assertNotEquals(SubscriptionType.SHARED, SubscriptionType.FAILOVER);
        assertNotEquals(SubscriptionType.SHARED, SubscriptionType.KEY_SHARED);
        assertNotEquals(SubscriptionType.FAILOVER, SubscriptionType.KEY_SHARED);
    }
}